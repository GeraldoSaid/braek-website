<IfModule mod_rewrite.c>
    RewriteEngine On

    # Prevent infinite loops
    RewriteCond %{ENV:REDIRECT_STATUS} ^$

    # 301 Redirect /index to /
    RewriteRule ^index$ / [R=301,L]

    # Redirect nothing (the root) to the subfolder
    RewriteRule ^$ /braek-website/ [L]

    # Handle clean URLs (remove .html extension)
    # Check if the requested URL (without .html) exists as a .html file in the subfolder
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{DOCUMENT_ROOT}/braek-website/$1.html -f
    RewriteRule ^(.*)$ /braek-website/$1.html [L]

    # Fallback: Redirect everything else to the subfolder directly
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} !^/braek-website/
    RewriteRule ^(.*)$ /braek-website/$1 [L]
</IfModule>
