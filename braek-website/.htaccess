# ─── PHP configuration ─────────────────────────────────────
# (Removed php_value directives to avoid 500/403 errors on strict shared hosting)

# ─── Security headers ───────────────────────────────────────
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ─── Hide sensitive files ───────────────────────────────────
<FilesMatch "\.(sql|env|log|sh|json)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Allow projects.json specifically (it's a fallback)
<Files "projects.json">
    Order allow,deny
    Allow from all
</Files>

# ─── Pretty URLs (optional, for future routing) ─────────────
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /
</IfModule>
